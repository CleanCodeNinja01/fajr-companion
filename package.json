{
  "name": "fajr-companion",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "bash scripts/with-android-env.sh expo start --dev-client",
    "start:ios": "expo start --dev-client --ios",
    "start:android": "bash scripts/with-android-env.sh expo start --dev-client --android",
    "android": "bash scripts/with-android-env.sh env LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash -c 'node scripts/patch-android-splash.js && expo run:android'",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios",
    "test": "jest",
    "generate:assets": "node scripts/generate-brand-assets.mjs",
    "postprebuild": "node scripts/patch-android-splash.js",
    "postinstall": "node scripts/patch-android-splash.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "adhan": "^4.4.3",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.0",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-colors": "^2.6.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "tz-lookup": "^6.1.25"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "sharp": "^0.35.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
