{
  "expo": {
    "name": "Fajr Companion",
    "slug": "fajr-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#1A0E12",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1A0E12"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "backgroundColor": "#1A0E12",
      "bundleIdentifier": "com.fajrcompanion.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to calculate your local Fajr prayer time.",
        "NSCameraUsageDescription": "Used to take a photo of your prayer mat as wake-up verification.",
        "NSMicrophoneUsageDescription": "Required by camera."
      }
    },
    "android": {
      "backgroundColor": "#1A0E12",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A0E12"
      },
      "package": "com.fajrcompanion.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "posthogApiKey": "",
      "posthogHost": "https://us.i.posthog.com"
    },
    "plugins": [
      "expo-dev-client",
      ["expo-notifications", {
        "color": "#7C3D52",
        "defaultChannel": "fajr-alarm",
        "enableBackgroundRemoteNotifications": false
      }],
      ["expo-location", {
        "locationWhenInUsePermission": "Allow Fajr Companion to use your location to calculate prayer times."
      }],
      "expo-image-picker",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A0E12",
          "image": "./assets/splash.png",
          "resizeMode": "cover"
        }
      ]
    ]
  }
}
