# Google Cloud Vision — required for prayer mat photo verification
# Free tier: 1,000 requests/month (enough for ~33 daily active users)
# Setup: console.cloud.google.com → APIs → Cloud Vision API → Credentials → API Key
EXPO_PUBLIC_GOOGLE_VISION_API_KEY=

# PostHog analytics (optional — app works without these)
# Sign up free at https://posthog.com → Project Settings → Project API Key
EXPO_PUBLIC_POSTHOG_API_KEY=
# EU cloud: https://eu.i.posthog.com
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
